values_df <- raw_df_2 |>
slice(-c(1,2)) |>
# remove test data
filter(!is.na(QID1) & QID1 != '.') |>
# remove free response survey data (not demographics though)
select(-`VBQ-Y`, -`VBQ-N`, -`Q-SIB-N`,
